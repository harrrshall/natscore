# NatScore -- centralized credentials (per AGENTS.md guidance)
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Source it before running scripts:
#     set -a; source .env; set +a
# Or use direnv: `direnv allow` after creating .envrc with `dotenv`.
#
# All four are required for the full M1 -> M6 pipeline. The local
# scaffold/lint/test does not need any of them.

# HuggingFace -- required for dataset download (M1) and model upload (M6)
# Get from https://huggingface.co/settings/tokens (need at least `read` scope;
# `write` scope required only for M6 model upload).
# Also visit https://huggingface.co/datasets/RMSnow/SpeechJudge-Data and
# click "Agree and access repository" before M1 will work.
HF_TOKEN=

# Weights & Biases -- required for M3 training-run metrics
# Get from https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=natscore
WANDB_ENTITY=

# Kaggle -- primary free T4 surface for feature extraction (M2) and training (M3)
# Get from https://www.kaggle.com/settings/account ("Create New Token")
# Place ~/.config/kaggle/kaggle.json OR export these:
KAGGLE_USERNAME=
KAGGLE_KEY=

# Modal -- paid fallback compute (only if Kaggle quota exceeded)
# `modal token new` writes ~/.modal.toml; these vars are only needed for CI.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
